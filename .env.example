SERVER_PORT=8080
APP_SECURITY_ENABLED=true
APP_SECURITY_USERNAME=admin
APP_SECURITY_PASSWORD=troque-esta-senha
APP_SECURITY_JWT_SECRET=troque-este-segredo-jwt
APP_SECURITY_TOKEN_MINUTES=60
APP_SECURITY_MAX_LOGIN_ATTEMPTS=5
APP_SECURITY_LOCK_MINUTES=15
APP_SECURITY_LOGIN_RATE_LIMIT_PER_MINUTE=20
# Alternativa para Docker Secrets/arquivos protegidos:
# APP_SECURITY_JWT_SECRET_FILE=/run/secrets/ultimo_andar_jwt_secret
APP_CRYPTO_KEY=troque-esta-chave-de-criptografia
# APP_CRYPTO_KEY_FILE=/run/secrets/ultimo_andar_crypto_key
APP_RETENTION_AUDIT_DAYS=365
APP_H2_CONSOLE_ENABLED=true
SERVER_SSL_ENABLED=false
# SERVER_SSL_KEY_STORE=/app/certs/ultimo-andar.p12
# SERVER_SSL_KEY_STORE_PASSWORD=troque-esta-senha
APP_COMPANY_CNPJ=00.000.000/0001-00
APP_COMPANY_ADDRESS=Endereço administrativo da Último Andar
APP_PRIVACY_EMAIL=privacidade@ultimoandar.local
APP_DEFAULT_CITY=São Paulo
APP_DEFAULT_FORUM=São Paulo/SP

POSTGRES_DB=ultimo_andar
POSTGRES_USER=ultimo_andar
POSTGRES_PASSWORD=ultimo_andar
